<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.openocta.launcher</string>

    <key>ProgramArguments</key>
    <array>
      <string>/Applications/OpenOcta.app/Contents/MacOS/OpenOcta</string>
    </array>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/tmp/openocta-launcher.out</string>
    <key>StandardErrorPath</key>
    <string>/tmp/openocta-launcher.err</string>
  </dict>
</plist>

